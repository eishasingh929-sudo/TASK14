UNIGURU_HOST=0.0.0.0
UNIGURU_PORT=8000
UNIGURU_ENGINE_URL=http://127.0.0.1:8000/ask
UNIGURU_BRIDGE_URL=http://127.0.0.1:8002/chat
NODE_BACKEND_PORT=3000
UNIGURU_ASK_URL=http://127.0.0.1:8000/ask
UNIGURU_REQUEST_TIMEOUT_MS=15000
UNIGURU_LLM_URL=http://127.0.0.1:11434/api/generate
UNIGURU_LLM_MODEL=gpt-oss:120b-cloud
UNIGURU_LLM_TIMEOUT_SECONDS=12
UNIGURU_WORKERS=4
UNIGURU_LOG_LEVEL=INFO
UNIGURU_RATE_LIMIT_WINDOW_SECONDS=60
UNIGURU_RATE_LIMIT_MAX_REQUESTS=100
UNIGURU_API_AUTH_REQUIRED=true
UNIGURU_API_TOKEN=replace-with-secure-token
UNIGURU_API_TOKENS=comma-separated-rotation-tokens
UNIGURU_DEMO_SERVICE_TOKEN=uniguru-demo-token
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,samachar-platform,internal-testing,uniguru-frontend
UNIGURU_METRICS_STATE_FILE=/var/lib/uniguru/metrics_state.json
UNIGURU_ROUTER_QUEUE_LIMIT=200
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=1200
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=30
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true
UNIGURU_LANGUAGE_ADAPTER_ENABLED=true
UNIGURU_LANGUAGE_ADAPTER_DEFAULT_LANGUAGE=en
UNIGURU_BUCKET_TELEMETRY_ENABLED=true
UNIGURU_BUCKET_TELEMETRY_ENDPOINT=https://bucket.bhiv.local/events
UNIGURU_BUCKET_TELEMETRY_TOKEN=replace-with-bucket-token
UNIGURU_BUCKET_TELEMETRY_TIMEOUT_SECONDS=2.0
UNIGURU_CORE_READER_ENABLED=true
UNIGURU_CORE_BASE_URL=https://core.bhiv.local
UNIGURU_CORE_TOKEN=replace-with-core-token
UNIGURU_CORE_TIMEOUT_SECONDS=2.0
