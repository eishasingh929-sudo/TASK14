UNIGURU_HOST=0.0.0.0
UNIGURU_PORT=8000
UNIGURU_ENGINE_URL=http://127.0.0.1:8000/ask
UNIGURU_BRIDGE_URL=http://127.0.0.1:8002/chat
NODE_BACKEND_PORT=8080
UNIGURU_ASK_URL=http://127.0.0.1:8000/ask
UNIGURU_REQUEST_TIMEOUT_MS=15000
UNIGURU_LLM_URL=internal://demo-llm
UNIGURU_LLM_MODEL=demo-safety-llm
UNIGURU_LLM_TIMEOUT_SECONDS=20
UNIGURU_WORKERS=2
UNIGURU_LOG_LEVEL=INFO
UNIGURU_RATE_LIMIT_WINDOW_SECONDS=60
UNIGURU_RATE_LIMIT_MAX_REQUESTS=60
UNIGURU_API_AUTH_REQUIRED=true
UNIGURU_API_TOKEN=replace-with-strong-token
UNIGURU_API_TOKENS=
UNIGURU_DEMO_SERVICE_TOKEN=uniguru-demo-token
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,internal-testing,uniguru-frontend
UNIGURU_METRICS_STATE_FILE=/var/lib/uniguru/metrics_state.json
UNIGURU_ROUTER_QUEUE_LIMIT=200
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=1200
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=30
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true
UNIGURU_LANGUAGE_ADAPTER_ENABLED=true
UNIGURU_LANGUAGE_ADAPTER_DEFAULT_LANGUAGE=en
UNIGURU_BUCKET_TELEMETRY_ENABLED=false
UNIGURU_BUCKET_TELEMETRY_ENDPOINT=
UNIGURU_BUCKET_TELEMETRY_TOKEN=
UNIGURU_BUCKET_TELEMETRY_TIMEOUT_SECONDS=2.0
UNIGURU_CORE_READER_ENABLED=false
UNIGURU_CORE_BASE_URL=
UNIGURU_CORE_TOKEN=
UNIGURU_CORE_TIMEOUT_SECONDS=2.0
