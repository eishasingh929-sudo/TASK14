UNIGURU_HOST=127.0.0.1
UNIGURU_PORT=8000
NODE_BACKEND_PORT=8080
UNIGURU_ASK_URL=http://127.0.0.1:8000/ask

# Auth: keep false for demo safety mode, set true for secured environments.
UNIGURU_API_AUTH_REQUIRED=false
UNIGURU_API_TOKEN=replace-with-strong-token
UNIGURU_API_TOKENS=
UNIGURU_DEMO_SERVICE_TOKEN=uniguru-demo-token
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,internal-testing,uniguru-frontend

# LLM routing: defaults keep ROUTE_LLM always available.
UNIGURU_LLM_URL=http://127.0.0.1:11434/api/generate
UNIGURU_LLM_MODEL=gpt-oss:120b-cloud
UNIGURU_LLM_TIMEOUT_SECONDS=60

# Resilience controls
UNIGURU_KB_CONFIDENCE_THRESHOLD=0.45
UNIGURU_KB_EXTRA_PATHS=
UNIGURU_EXTRA_DATASET_DIRS=
UNIGURU_ROUTER_QUEUE_LIMIT=200
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=1200
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=30
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true
